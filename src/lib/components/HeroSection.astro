---
import { Image } from "astro:assets";
import heroBg from "../../assets/images/hero-background.webp";
import { hero } from "../../data/content";
---

<section id="hero" class="relative flex min-h-screen items-center overflow-hidden">
	<!-- Video Background with parallax wrapper -->
	<div class="parallax-bg absolute inset-0">
		<video
			autoplay
			muted
			loop
			playsinline
			class="absolute inset-0 h-[120%] w-full object-cover"
		>
			<source src="/video/hero-video.mp4" type="video/mp4" />
		</video>
		<!-- Fallback poster image -->
		<Image
			src={heroBg}
			alt=""
			class="absolute inset-0 h-[120%] w-full object-cover"
			widths={[800, 1200, 1920]}
			sizes="100vw"
			loading="eager"
			style="z-index: -1;"
		/>
	</div>

	<!-- Cinematic overlays -->
	<div class="absolute inset-0 bg-linear-to-t from-background via-background/75 to-background/20"></div>
	<div class="absolute inset-0 bg-linear-to-r from-background/80 via-background/40 to-transparent"></div>
	<!-- Film grain texture -->
	<div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 128px;"></div>

	<!-- Content -->
	<div class="relative z-10 mx-auto w-full max-w-7xl px-6 pt-32 pb-24">
		<div class="max-w-3xl">
			<!-- Brand accent line -->
			<div class="mb-8 flex items-center gap-3">
				<div class="h-px w-16 bg-linear-to-r from-brand-orange to-brand-gold"></div>
				<span class="text-xs font-semibold uppercase tracking-[0.4em] text-primary">Calisthenics</span>
			</div>

			<!-- Headline — reduced size, tighter -->
			<h1 class="text-4xl leading-[0.95] sm:text-5xl md:text-6xl lg:text-7xl">
				ПОСТРОЙ СИЛУ,<br />
				КОТОРАЯ С ТОБОЙ
				<span class="bg-linear-to-r from-brand-orange to-brand-gold bg-clip-text text-transparent italic">
					НАВСЕГДА.
				</span>
			</h1>

			<!-- One-liner description -->
			<p class="mt-8 max-w-md text-lg text-foreground/70 leading-relaxed">
				{hero.description}
			</p>

			<!-- CTA -->
			<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
				<a
					href="https://t.me/vvb_CALIATHLETICS_bot" target="_blank" rel="noopener noreferrer"
					class="group inline-flex items-center justify-center gap-3 rounded-full bg-linear-to-r from-brand-orange to-brand-gold px-8 py-4 text-base font-semibold text-background transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,132,0,0.4)]"
				>
					{hero.cta}
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
					</svg>
				</a>
				<a href="#program" class="inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-primary">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
					Узнать больше
				</a>
			</div>

			<!-- Compact stats row -->
			<div class="mt-14 flex items-center gap-8 border-t border-border/30 pt-8">
				<div>
					<div class="font-display text-3xl text-primary">600+</div>
					<div class="mt-1 text-xs uppercase tracking-wider text-muted-foreground">клиентов</div>
				</div>
				<div class="h-10 w-px bg-border/30"></div>
				<div>
					<div class="font-display text-3xl text-primary">5+</div>
					<div class="mt-1 text-xs uppercase tracking-wider text-muted-foreground">лет опыта</div>
				</div>
				<div class="h-10 w-px bg-border/30"></div>
				<div>
					<div class="font-display text-3xl text-foreground/80">4 дня</div>
					<div class="mt-1 text-xs uppercase tracking-wider text-muted-foreground">в неделю</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
		<div class="flex flex-col items-center gap-2">
			<span class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground/60">Scroll</span>
			<div class="h-8 w-px bg-linear-to-b from-primary/60 to-transparent"></div>
		</div>
	</div>
</section>

<script>
	// Simple parallax for hero background
	const parallaxBg = document.querySelector('.parallax-bg') as HTMLElement;
	if (parallaxBg) {
		window.addEventListener('scroll', () => {
			const scrollY = window.scrollY;
			const heroHeight = (parallaxBg.parentElement as HTMLElement).offsetHeight;
			if (scrollY < heroHeight) {
				parallaxBg.style.transform = `translateY(${scrollY * 0.3}px)`;
			}
		}, { passive: true });
	}
</script>
