---
import { programs } from "../../data/content";

const programMeta = [
	{ level: "Начинающий", color: "text-emerald-400", border: "border-emerald-500/20 hover:border-emerald-500/40", icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" },
	{ level: "Средний", color: "text-amber-400", border: "border-amber-500/20 hover:border-amber-500/40", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
	{ level: "Продвинутый", color: "text-red-400", border: "border-red-500/20 hover:border-red-500/40", icon: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" },
	{ level: "Гибкость", color: "text-purple-400", border: "border-purple-500/20 hover:border-purple-500/40", icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" },
	{ level: "Нижняя часть", color: "text-sky-400", border: "border-sky-500/20 hover:border-sky-500/40", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
];
---

<section id="catalog" class="relative overflow-hidden py-24 sm:py-32">
	<div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-primary/3 blur-3xl"></div>

	<div class="relative mx-auto max-w-7xl px-6">
		<!-- Section header -->
		<div class="reveal text-center">
			<span class="text-sm font-medium uppercase tracking-widest text-primary">Каталог</span>
			<h2 class="mt-4 text-4xl sm:text-5xl md:text-6xl">
				ИЩЕТЕ
				<span class="bg-linear-to-r from-brand-orange to-brand-gold bg-clip-text text-transparent">ПРОГРАММУ</span>?
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-lg text-muted-foreground">
				{programs.subtitle}
			</p>
		</div>

		<!-- Programs grid -->
		<div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{programs.items.map((prog, i) => {
				const meta = programMeta[i];
				return (
					<div class={`group relative overflow-hidden rounded-2xl border bg-card/30 p-6 backdrop-blur-sm transition-all duration-500 hover:bg-card/60 hover:shadow-[0_0_30px_rgba(255,132,0,0.06)] ${meta.border}`}>
						<!-- Header -->
						<div class="flex items-start justify-between gap-4">
							<div>
								<span class={`text-xs font-medium uppercase tracking-wider ${meta.color}`}>{meta.level}</span>
								<h3 class="mt-1 font-display text-xl tracking-wide leading-tight">{prog.name}</h3>
							</div>
							<div class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-card/80 ${meta.color}`}>
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d={meta.icon} />
								</svg>
							</div>
						</div>

						<!-- Stats row -->
						<div class="mt-6 flex items-center gap-3">
							<div class="flex-1 rounded-lg bg-background/40 px-3 py-2 text-center">
								<div class="font-display text-xl text-foreground">{prog.levels}</div>
								<div class="text-[10px] uppercase tracking-wider text-muted-foreground">уровней</div>
							</div>
							<div class="flex-1 rounded-lg bg-background/40 px-3 py-2 text-center">
								<div class="font-display text-xl text-foreground">{prog.exercises}</div>
								<div class="text-[10px] uppercase tracking-wider text-muted-foreground">упражн.</div>
							</div>
							<div class="flex-1 rounded-lg bg-background/40 px-3 py-2 text-center">
								<div class="font-display text-xl text-foreground">{prog.videos}</div>
								<div class="text-[10px] uppercase tracking-wider text-muted-foreground">видео</div>
							</div>
							<div class="flex-1 rounded-lg bg-background/40 px-3 py-2 text-center">
								<div class="font-display text-xl text-foreground">{prog.skills}</div>
								<div class="text-[10px] uppercase tracking-wider text-muted-foreground">навыков</div>
							</div>
						</div>

						<!-- CTA -->
						<a
							href="#contact"
							class="mt-5 flex w-full items-center justify-center gap-2 rounded-xl border border-border/50 bg-card/50 py-2.5 text-sm font-medium text-foreground transition-all duration-300 hover:border-primary/30 hover:text-primary"
						>
							Подробнее
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
					</div>
				);
			})}
		</div>
	</div>
</section>
