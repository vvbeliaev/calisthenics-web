---
import { programs } from "../data/content";

const programIcons = [
	"🟢", // Beginner
	"🟡", // Intermediate
	"🔴", // Advanced
	"🟣", // Flexibility
	"🔵", // Lower body
];

const programAccents = [
	"border-emerald-500/20 hover:border-emerald-500/40",
	"border-amber-500/20 hover:border-amber-500/40",
	"border-red-500/20 hover:border-red-500/40",
	"border-purple-500/20 hover:border-purple-500/40",
	"border-sky-500/20 hover:border-sky-500/40",
];
---

<section id="catalog" class="relative overflow-hidden py-24 sm:py-32">
	<div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-primary/3 blur-3xl"></div>

	<div class="relative mx-auto max-w-7xl px-6">
		<!-- Section header -->
		<div class="text-center">
			<span class="text-sm font-medium uppercase tracking-widest text-primary">Каталог</span>
			<h2 class="mt-4 text-4xl sm:text-5xl md:text-6xl">
				{programs.title.replace("?", "").toUpperCase()}
				<span class="bg-linear-to-r from-brand-orange to-brand-gold bg-clip-text text-transparent">?</span>
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-lg text-muted-foreground">
				{programs.subtitle}
			</p>
		</div>

		<!-- Programs grid -->
		<div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{programs.items.map((prog, i) => (
				<div class={`group relative rounded-2xl border bg-card/50 p-6 backdrop-blur-sm transition-all duration-500 hover:bg-card/80 hover:shadow-[0_0_30px_rgba(255,132,0,0.06)] ${programAccents[i]}`}>
					<div class="mb-4 text-3xl">{programIcons[i]}</div>
					<h3 class="font-display text-xl tracking-wide leading-tight">{prog.name}</h3>

					<!-- Stats grid -->
					<div class="mt-6 grid grid-cols-2 gap-4">
						<div class="rounded-lg bg-background/50 p-3 text-center">
							<div class="font-display text-2xl text-primary">{prog.levels}</div>
							<div class="text-xs text-muted-foreground">уровней</div>
						</div>
						<div class="rounded-lg bg-background/50 p-3 text-center">
							<div class="font-display text-2xl text-primary">{prog.exercises}</div>
							<div class="text-xs text-muted-foreground">упражнений</div>
						</div>
						<div class="rounded-lg bg-background/50 p-3 text-center">
							<div class="font-display text-2xl text-primary">{prog.videos}</div>
							<div class="text-xs text-muted-foreground">видео</div>
						</div>
						<div class="rounded-lg bg-background/50 p-3 text-center">
							<div class="font-display text-2xl text-primary">{prog.skills}</div>
							<div class="text-xs text-muted-foreground">навыков</div>
						</div>
					</div>

					<a
						href="#contact"
						class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl border border-primary/30 bg-primary/5 py-3 text-sm font-medium text-primary transition-all duration-300 hover:bg-primary/10 hover:border-primary/50"
					>
						Подробнее
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</a>
				</div>
			))}
		</div>
	</div>
</section>
