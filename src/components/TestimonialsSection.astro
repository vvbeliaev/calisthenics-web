---
import { Image } from "astro:assets";
import { testimonials } from "../data/content";

// Import images statically for Astro
import t01 from "../assets/images/testimonial-01.webp";
import t02 from "../assets/images/testimonial-02.webp";
import t03 from "../assets/images/testimonial-03.webp";
import t04 from "../assets/images/testimonial-04.webp";
import t05 from "../assets/images/testimonial-05.webp";
import t06 from "../assets/images/testimonial-06.webp";
import av1 from "../assets/images/avatar-1.png";
import av2 from "../assets/images/avatar-2.png";
import av3 from "../assets/images/avatar-3.png";

const images = [
	{ before: t01, after: t02, avatar: av1 },
	{ before: t03, after: t04, avatar: av2 },
	{ before: t05, after: t06, avatar: av3 },
];
---

<section id="testimonials" class="relative overflow-hidden py-24 sm:py-32">
	<!-- Background glow -->
	<div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-primary/3 blur-3xl"></div>
	<div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-accent/3 blur-3xl"></div>

	<div class="relative mx-auto max-w-7xl px-6">
		<!-- Section header -->
		<div class="text-center">
			<span class="text-sm font-medium uppercase tracking-widest text-primary">Результаты</span>
			<h2 class="mt-4 text-4xl sm:text-5xl md:text-6xl">
				{testimonials.title.split("!")[0]}
				<span class="bg-linear-to-r from-brand-orange to-brand-gold bg-clip-text text-transparent">!</span>
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-lg text-muted-foreground">
				{testimonials.subtitle}
			</p>
		</div>

		<!-- Testimonial cards -->
		<div class="mt-16 space-y-16">
			{testimonials.items.map((item, i) => {
				const imgs = images[i];
				const isReversed = i % 2 !== 0;
				return (
					<div class={`grid items-center gap-8 lg:grid-cols-2 ${isReversed ? 'lg:direction-rtl' : ''}`}>
						<!-- Before / After -->
						<div class={`relative grid grid-cols-2 gap-4 ${isReversed ? 'lg:order-2' : ''}`}>
							<div class="relative overflow-hidden rounded-2xl border border-border/30">
								<span class="absolute top-3 left-3 z-10 rounded-full bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm">До</span>
								<Image
									src={imgs.before}
									alt={`${item.name} до`}
									class="h-full w-full object-cover aspect-[3/4]"
									widths={[300, 500]}
									sizes="(max-width: 1024px) 45vw, 22vw"
								/>
							</div>
							<div class="relative overflow-hidden rounded-2xl border border-primary/30 shadow-[0_0_20px_rgba(255,132,0,0.1)]">
								<span class="absolute top-3 left-3 z-10 rounded-full bg-primary/90 px-3 py-1 text-xs font-medium text-background backdrop-blur-sm">После</span>
								<Image
									src={imgs.after}
									alt={`${item.name} после`}
									class="h-full w-full object-cover aspect-[3/4]"
									widths={[300, 500]}
									sizes="(max-width: 1024px) 45vw, 22vw"
								/>
							</div>
						</div>

						<!-- Text -->
						<div class={`${isReversed ? 'lg:order-1' : ''}`}>
							<div class="flex items-center gap-4">
								<Image
									src={imgs.avatar}
									alt={item.name}
									class="h-14 w-14 rounded-full border-2 border-primary/30 object-cover"
									width={56}
									height={56}
								/>
								<div>
									<h3 class="font-display text-2xl tracking-wide">{item.name}</h3>
								</div>
							</div>
							<blockquote class="mt-6 border-l-2 border-primary/30 pl-6">
								<p class="text-muted-foreground leading-relaxed italic">
									"{item.text}"
								</p>
							</blockquote>
						</div>
					</div>
				);
			})}
		</div>
	</div>
</section>
