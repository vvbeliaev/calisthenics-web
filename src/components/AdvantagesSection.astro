---
import { Image } from "astro:assets";
import anatomyImg from "../assets/images/access-1.webp";

const offers = [
	{
		title: "Онлайн коучинг",
		description: "Комплексный план тренировок и питания, анализ техники по видео, постоянная связь и отчётность. Полное сопровождение, где бы вы ни находились.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
	},
	{
		title: "Персональные тренировки",
		description: "Очные занятия с разбором техники, мотивацией и максимальной эффективностью каждой минуты в зале.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
	},
	{
		title: "Гибридный формат",
		description: "Комбинация онлайн и очных тренировок. Для требовательных клиентов — максимальный результат.",
		icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
	},
];
---

<section id="advantages" class="relative overflow-hidden py-24 sm:py-32">
	<!-- Background glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-primary/5 blur-[120px]"></div>

	<div class="relative mx-auto max-w-7xl px-6">
		<!-- Section header — centered -->
		<div class="reveal mx-auto max-w-2xl text-center">
			<span class="text-sm font-medium uppercase tracking-widest text-primary">Путь к новому телу</span>
			<h2 class="mt-4 text-4xl sm:text-5xl md:text-6xl">
				МОЁ
				<span class="bg-linear-to-r from-brand-orange to-brand-gold bg-clip-text text-transparent">ПРЕДЛОЖЕНИЕ</span>
				ДЛЯ ВАС
			</h2>
			<p class="mt-6 text-muted-foreground leading-relaxed">
				Выберите путь к новому телу. Какой бы ни была ваша цель, у меня есть индивидуальное решение для вас.
			</p>
		</div>

		<!-- Symmetrical 3-column grid -->
		<div class="reveal mt-16 grid gap-6 md:grid-cols-3">
			{offers.map((offer, i) => (
				<div class="group relative overflow-hidden rounded-2xl border border-border/40 bg-card/20 p-8 backdrop-blur-sm transition-all duration-500 hover:border-primary/30 hover:bg-card/40 hover:shadow-[0_8px_40px_rgba(255,132,0,0.06)]">
					<!-- Icon -->
					<div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl border border-primary/20 bg-primary/5 text-primary transition-all duration-500 group-hover:border-primary/40 group-hover:bg-primary/10 group-hover:shadow-[0_0_20px_rgba(255,132,0,0.15)]">
						<Fragment set:html={offer.icon} />
					</div>

					<h3 class="font-display text-xl tracking-wide">{offer.title}</h3>
					<p class="mt-3 text-sm text-muted-foreground leading-relaxed">{offer.description}</p>

					<!-- Bottom accent line -->
					<div class="mt-8 h-px w-full bg-linear-to-r from-primary/0 via-primary/20 to-primary/0 transition-all duration-500 group-hover:via-primary/40"></div>
				</div>
			))}
		</div>

		<!-- CTA row with anatomy image -->
		<div class="reveal mt-12 overflow-hidden rounded-2xl border border-primary/20 bg-linear-to-r from-primary/5 via-card/30 to-primary/5">
			<div class="flex flex-col items-center gap-8 p-8 sm:flex-row sm:p-10">
				<div class="w-32 shrink-0 sm:w-40">
					<Image
						src={anatomyImg}
						alt="Анатомия мышц"
						class="w-full drop-shadow-[0_0_40px_rgba(255,132,0,0.25)]"
						widths={[160, 320]}
						sizes="160px"
					/>
				</div>
				<div class="flex-1 text-center sm:text-left">
					<h3 class="font-display text-2xl tracking-wide">ПОДРОБНОСТИ О ПРОГРАММЕ</h3>
					<p class="mt-2 text-sm text-muted-foreground">Узнайте детали и стоимость каждого формата тренировок</p>
				</div>
				<a
					href="#catalog"
					class="shrink-0 inline-flex items-center gap-2 rounded-full bg-linear-to-r from-brand-orange to-brand-gold px-6 py-3 text-sm font-semibold text-background transition-all duration-300 hover:scale-105 hover:shadow-[0_0_25px_rgba(255,132,0,0.3)]"
				>
					Смотреть каталог
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>
