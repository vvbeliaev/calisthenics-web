---
const advantages = [
	{
		icon: "calendar",
		title: "Чёткий график",
		description: "Пн, Вт, Чт, Пт — силовые тренировки. Ср, Сб, Вс — восстановление и растяжка.",
		accent: "from-brand-orange to-amber-500",
	},
	{
		icon: "trending-up",
		title: "Устойчивый рост",
		description: "Каждая тренировка прорабатывает всё тело. Прогресс виден уже через 4 недели.",
		accent: "from-brand-gold to-yellow-400",
	},
	{
		icon: "body",
		title: "Без оборудования",
		description: "Твоё тело — твой главный снаряд. Тренируйся дома, на площадке, в парке.",
		accent: "from-orange-400 to-brand-orange",
	},
	{
		icon: "levels",
		title: "Система прогрессии",
		description: "Каждое упражнение имеет уровни сложности — от новичка до профи.",
		accent: "from-brand-orange to-brand-gold",
	},
];
---

<section id="advantages" class="relative overflow-hidden py-24 sm:py-32">
	<!-- Background glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-primary/5 blur-3xl"></div>

	<div class="relative mx-auto max-w-7xl px-6">
		<!-- Section header -->
		<div class="text-center">
			<span class="text-sm font-medium uppercase tracking-widest text-primary">Почему калистеника</span>
			<h2 class="mt-4 text-4xl sm:text-5xl md:text-6xl">
				ПРЕИМУЩЕСТВА
				<span class="bg-linear-to-r from-brand-orange to-brand-gold bg-clip-text text-transparent">
					ТРЕНИРОВОК
				</span>
			</h2>
			<p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
				Калистеника — это не просто упражнения. Это философия свободы, контроля над телом и бесконечного прогресса.
			</p>
		</div>

		<!-- Cards grid -->
		<div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{advantages.map((item, i) => (
				<div class="group relative rounded-2xl border border-border/50 bg-card/50 p-8 backdrop-blur-sm transition-all duration-500 hover:border-primary/30 hover:bg-card/80 hover:shadow-[0_0_30px_rgba(255,132,0,0.08)]">
					<!-- Number -->
					<span class="absolute top-6 right-6 font-display text-5xl text-foreground/5 transition-colors group-hover:text-primary/10">
						0{i + 1}
					</span>

					<!-- Icon -->
					<div class={`mb-6 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-linear-to-br ${item.accent} shadow-lg`}>
						{item.icon === "calendar" && (
							<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-background" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
						)}
						{item.icon === "trending-up" && (
							<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-background" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
							</svg>
						)}
						{item.icon === "body" && (
							<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-background" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
							</svg>
						)}
						{item.icon === "levels" && (
							<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-background" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
							</svg>
						)}
					</div>

					<h3 class="text-xl font-display tracking-wide text-foreground">{item.title}</h3>
					<p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
